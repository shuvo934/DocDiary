<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="@dimen/_10sdp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:id="@+id/icon_doc_diary_default"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/doc_diary_default"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="0dp"
            android:layout_toEndOf="@+id/icon_doc_diary_default"
            android:fontFamily="@font/poppins_bold"
            android:text="WARNING!"
            android:textColor="@color/green_sea"
            android:textSize="@dimen/_13sdp"
            tools:ignore="HardcodedText" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/light_green"/>

    <TextView
        android:id="@+id/error_message_for_handler"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_margin="@dimen/_8sdp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/default_text_color"
        android:gravity="start" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="@dimen/_12sdp"
        android:layout_marginBottom="@dimen/_4sdp"
        android:weightSum="9">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/log_out_button_for_handler"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            app:icon="@drawable/logout_24"
            app:iconSize="@dimen/_13sdp"
            app:iconTint="@color/white"
            app:iconPadding="0dp"
            android:layout_margin="@dimen/_8sdp"
            android:text="LOG OUT"
            app:cornerRadius="@dimen/_8sdp"
            android:textColor="@color/white"
            android:fontFamily="@font/lato_bold"
            android:paddingStart="@dimen/_8sdp"
            android:paddingEnd="@dimen/_2sdp"
            android:textSize="@dimen/_9sdp"
            tools:ignore="HardcodedText" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exit_button_for_handler"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_8sdp"
            android:text="EXIT"
            app:cornerRadius="@dimen/_8sdp"
            android:textColor="@color/white"
            android:fontFamily="@font/lato_bold"
            android:textSize="@dimen/_9sdp"
            tools:ignore="HardcodedText" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/retry_button_for_handler"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_8sdp"
            android:text="RETRY"
            app:cornerRadius="@dimen/_8sdp"
            android:textColor="@color/white"
            android:fontFamily="@font/lato_bold"
            android:textSize="@dimen/_9sdp"
            tools:ignore="HardcodedText" />

    </LinearLayout>


</LinearLayout>